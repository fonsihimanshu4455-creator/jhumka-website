# ---- Backend environment ----

# Port the Express server listens on
PORT=5000

# MongoDB Atlas connection string
# e.g. mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/jhumka?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/jhumka

# Secret used to sign admin JWTs (use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret

# How long issued tokens stay valid
JWT_EXPIRES_IN=7d

# Default admin account created by the seed script
ADMIN_EMAIL=admin@jhumka.com
ADMIN_PASSWORD=admin123

# Comma-separated list of allowed CORS origins (frontend URLs)
CLIENT_ORIGIN=http://localhost:5173

# Public base URL of this server (used to build absolute image URLs)
SERVER_URL=http://localhost:5000
