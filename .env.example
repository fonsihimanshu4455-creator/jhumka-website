# ---- Frontend (Vite) environment ----

# Supabase project URL, e.g. https://abcdxyz.supabase.co
VITE_SUPABASE_URL=

# Supabase "anon" public API key (safe to expose in the browser).
# Project → Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=

# WhatsApp number for checkout (international format, digits only, no + or spaces)
VITE_WHATSAPP_NUMBER=919999999999

# ---- Razorpay (online payments) ----
# These are SERVER-side keys used by the /api functions — set them in Vercel
# (NOT prefixed with VITE_, so they never reach the browser). Listed here for
# reference only.
#   RAZORPAY_KEY_ID=rzp_live_xxxxxxxx     (or rzp_test_xxxxxxxx)
#   RAZORPAY_KEY_SECRET=your-razorpay-secret
